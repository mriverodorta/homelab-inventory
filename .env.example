# Optional overrides. The Docker image already defaults to these values.
NODE_ENV=production
PORT=8798
DATA_DIR=/data
SAVE_DEBOUNCE_MS=500

# Runtime mode: production app behavior or public demo sandbox behavior.
# Use NODE_ENV=production with APP_MODE=demo in Docker.
APP_MODE=production

# Anonymous Docker Hub update checks. Set latest for main-channel images,
# or false to disable all outbound update-check requests.
UPDATE_CHANNEL=stable
UPDATE_CHECK_ENABLED=true

# Demo mode only.
DEMO_SOURCE_DIR=/read-only-data
DEMO_SESSION_MINUTES=30
DEMO_MAX_SESSIONS=100

# Development note:
# bun run dev uses local ./data and can seed fictional sample data when empty.
